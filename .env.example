# =========================================
# LLM Configuration (SiliconFlow / DeepSeek)
# =========================================
# Get your API key from: https://cloud.siliconflow.cn/
API_KEY="YOUR_API_KEY_HERE"
BASE_URL="https://api.siliconflow.cn/v1"
MODEL_NAME="Qwen/Qwen2-7B-Instruct"

# =========================================
# ChromaDB and Embedding Configuration
# =========================================
# Path to the pre-built ChromaDB directory (relative to project root)
CHROMA_PERSIST_DIR_RELATIVE="external/chromaDB"
# Name of the sentence-transformer model
EMBEDDING_MODEL_NAME="BAAI/bge-large-zh"
# Name of the collection inside ChromaDB
CHROMA_COLLECTION_NAME="medical_markdown_data"

# =========================================
# Optional: Local Model Path
# =========================================
# Path to the local HuatuoGPT-Vision model directory
HUATUOGPT_VISION_MODEL_PATH="./huatuoGPT-Vision"
